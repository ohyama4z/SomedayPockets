{
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(/docs/**)",
      "Edit(/app/**)",
      "Edit(/.gitignore)",
      "Write(/tmp/*)",
      "Write(/docs/**)",
      "Write(/app/**)",
      "Glob",
      "Grep",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git log *)",
      "Bash(git log)",
      "Bash(git branch *)",
      "Bash(git branch)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(mkdir *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(gh issue *)",
      "Bash(gh label *)",
      "Bash(bash .claude/scripts/turn-counter.sh)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*secret*)",
      "Read(**/*credential*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "command": "bash .claude/scripts/turn-counter.sh"
          }
        ]
      }
    ]
  }
}